# Empty = same-origin /api (Docker nginx or craco devServer proxy). Override only if you serve API on another host.
REACT_APP_BACKEND_URL=
# Dev-only: where craco proxies /api (yarn start)
REACT_APP_API_PROXY_TARGET=http://127.0.0.1:8000
ENABLE_HEALTH_CHECK=false
# Audit workspace v2 UI (sparklines, extended KPIs). Set to false to disable.
# REACT_APP_AUDIT_WORKSPACE_V2=true